          </p>

          <form action="/contact" method="POST">
            <div class="row g-3" style="margin:0;">

              <div class="col-12 col-md-6">
                <input name="firstName" type="text" class="form-control" placeholder="Enter Your First Name"
                  style="border:0; padding:12px 14px; border-radius:12px; background:#ffffff;
                         box-shadow:0 10px 18px rgba(0,0,0,0.10), 0 0 0 1px rgba(0,0,0,0.04) inset; outline:none;">
              </div>

              <div class="col-12 col-md-6">
                <input name="lastName" type="text" class="form-control" placeholder="Enter Your Last Name"
                  style="border:0; padding:12px 14px; border-radius:12px; background:#ffffff;
                         box-shadow:0 10px 18px rgba(0,0,0,0.10), 0 0 0 1px rgba(0,0,0,0.04) inset; outline:none;">
              </div>

              <div class="col-12 col-md-6">
                <input name="phone" type="tel" class="form-control" placeholder="Enter Your Phone No"
                  style="border:0; padding:12px 14px; border-radius:12px; background:#ffffff;
                         box-shadow:0 10px 18px rgba(0,0,0,0.10), 0 0 0 1px rgba(0,0,0,0.04) inset; outline:none;">
              </div>

              <div class="col-12 col-md-6">
                <input name="email" type="email" class="form-control" placeholder="Enter Your Email"
                  style="border:0; padding:12px 14px; border-radius:12px; background:#ffffff;
                         box-shadow:0 10px 18px rgba(0,0,0,0.10), 0 0 0 1px rgba(0,0,0,0.04) inset; outline:none;">
              </div>

              <div class="col-12">
                <textarea name="message" class="form-control" rows="5" placeholder="Message"
                  style="border:0; padding:12px 14px; border-radius:12px; background:#ffffff;
                         box-shadow:0 10px 18px rgba(0,0,0,0.10), 0 0 0 1px rgba(0,0,0,0.04) inset;
                         outline:none; resize:vertical;"></textarea>
              </div>

              <div class="col-12">
                <button type="submit" class="btn w-100"
                  style="background:linear-gradient(135deg,#00d084,#198754);
                         color:#fff; padding:12px 14px; border-radius:12px;
                         font-weight:900; border:none; box-shadow:0 16px 28px rgba(15,81,50,0.28);">
                  Send Message
                </button>
              </div>

            </div>
          </form>

        </div>
