
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Reset Password | 9 Jobs Application Service</title>

  <style>
    :root{
      --navy:#0f766e;
      --text:#0f172a;
      --muted:#6b7280;
      --border:#e5e7eb;
      --bg:#115e59;
      --shadow: 0 14px 40px rgba(2, 6, 23, 0.10);
      --radius: 10px;
    }

    *{ box-sizing: border-box; }

    body{
      margin:0;
      font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, "Helvetica Neue", sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      display:flex;
      align-items:center;
      justify-content:center;
      padding: 24px;
    }

    .wrap{
      width: 100%;
      max-width: 600px;
      display:flex;
      justify-content:center;
    }

    .card{
      width: 420px;
      padding: 56px 56px 40px;
      border-radius: 14px;
      background: #fff;
      box-shadow: var(--shadow);
      text-align:center;
    }

    h1{
      margin: 0 0 10px;
      font-size: 30px;
      font-weight: 650;
      color: var(--navy);
      letter-spacing: 0.2px;
    }

    .sub{
      margin: 0 auto 30px;
      max-width: 420px;
      font-size: 14px;
      line-height: 1.6;
      color: var(--muted);
      text-align: justify;
    }

    .label{
      text-align:left;
      font-size: 14px;
      font-weight: 650;
      color: var(--navy);
      margin-bottom: 8px;
      margin-top: 14px;
    }

    .input{
      width: 100%;
      height: 44px;
      padding: 0 14px;
      border: 1px solid var(--border);
      border-radius: 6px;
      outline: none;
      font-size: 14px;
      color: var(--text);
      background: #fff;
    }

    .input:focus{
      border-color: rgba(15,118,110,0.6);
      box-shadow: 0 0 0 4px rgba(15,118,110,0.15);
    }

    .btn{
      width: 100%;
      height: 46px;
      border: 0;
      border-radius: 6px;
      background: var(--navy);
      color: #fff;
      font-size: 14px;
      font-weight: 650;
      cursor: pointer;
      margin-top: 26px;
      box-shadow: 0 10px 18px rgba(15,118,110,0.28);
    }

    .btn:hover{ filter: brightness(0.97); }
    .btn:active{ transform: translateY(1px); }

    .back{
      display:inline-block;
      margin-top: 22px;
      font-size: 18px;
      font-weight: 700;
      color: #6b7280;
      text-decoration: underline;
    }
    .back:hover{ color: var(--navy); }

    .alert{
      margin: 0 0 18px;
      padding: 10px 12px;
      border-radius: 8px;
      font-size: 13px;
      text-align: left;
    }

    .alert.error{
      background: #fef2f2;
      color: #991b1b;
      border: 1px solid #fecaca;
    }

    .alert.success{
      background: #f0fdf4;
      color: #166534;
      border: 1px solid #bbf7d0;
    }

    @media (max-width: 600px){
      .card{
        width: 100%;
        padding: 44px 22px 34px;
      }
      h1{ font-size: 26px; }
    }
  </style>
</head>

<body>
  <div class="wrap">
    <div class="card">
      <h1>Reset Your Password</h1>

      <p class="sub">
        Please enter your new password below. Make sure it is strong and easy for you to remember.
      </p>

    
  <% if (error) { %>
    <p style="color:red;"><%= error %></p>
  <% } %>

      <form  method="POST" action="/reset-password/<%= token %>?email=<%= encodeURIComponent(email) %>">
        <div class="label">New Password</div>
        <input
          class="input"
          type="password"
          name="password"
          placeholder="Enter new password"
          required
        />

        <div class="label">Confirm Password</div>
        <input
          class="input"
          type="password"
          name="confirmPassword"
          placeholder="Confirm new password"
          required
        />

        <button class="btn" type="submit">Update Password</button>
      </form>

      <a class="back" href="/login">Back to Sign In</a>
    </div>
  </div>
</body>
</html>











