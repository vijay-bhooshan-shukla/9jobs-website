<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>9 Jobs Application Service - Login</title>
  <link rel="icon" type="image/png" href="/img/logo-9.jpeg">

  <!-- Bootstrap Icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

  <style>
    :root{
      --card-max: 380px;
      --radius: 18px;
      --bg1: #0b1417;
      --bg2: #070f12;
      --card: rgba(22, 30, 34, .92);
      --stroke: rgba(255,255,255,.08);
      --text: rgba(255,255,255,.92);

      --field: rgba(255,255,255,.10);
      --field-stroke: rgba(255,255,255,.10);
      --field-text: rgba(255,255,255,.92);
      --field-placeholder: rgba(255,255,255,.35);

      --accent: #00f5a0;
      --accent2: #00d6ff;
      --link: #5fe3ff;

      --shadow: 0 22px 60px rgba(0,0,0,.55);
    }

    *{ box-sizing:border-box; }

    body{
      min-height:100vh;
      margin:0;
      display:flex;
      align-items:center;
      justify-content:center;
      padding:16px;
      font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      background:
        radial-gradient(1100px 700px at 30% 10%, rgba(0,245,160,.10), transparent 55%),
        radial-gradient(900px 650px at 80% 70%, rgba(0,214,255,.10), transparent 55%),
        linear-gradient(180deg, var(--bg1), var(--bg2));
      color: var(--text);
    }

    /* Card */
    .login-card{
      width:100%;
      max-width: var(--card-max);
      border-radius: var(--radius);
      background: var(--card);
      border: 1px solid var(--stroke);
      box-shadow: var(--shadow);
      overflow:hidden;
      position:relative;
      padding: 22px 20px 18px;
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      transform: translateZ(0);
      animation: pop .5s ease both;
    }

    /* top neon line */
    .login-card::before{
      content:"";
      position:absolute;
      left:0; right:0; top:0;
      height:4px;
      background: linear-gradient(90deg, #00ff7b, #b8ff00);
      box-shadow: 0 0 12px rgba(0,255,123,.45);
    }

    @keyframes pop{
      from{ opacity:0; transform: translateY(10px) scale(.98); }
      to{ opacity:1; transform: translateY(0) scale(1); }
    }

    /* Title */
    .title{
      text-align:center;
      font-weight:800;
      letter-spacing:.3px;
      margin: 6px 0 18px;
      font-size: 22px;
    }

    /* Labels */
    .label{
      display:block;
      color: rgba(255,255,255,.68);
      font-size: 12px;
      margin: 10px 0 6px;
      letter-spacing:.2px;
    }

    /* Fields */
    .field{
      width:100%;
      background: var(--field);
      border: 1px solid var(--field-stroke);
      border-radius: 10px;
      padding: 12px 12px;
      color: var(--field-text);
      outline: none;
      font-size: 14px;
      transition: border-color .2s ease, box-shadow .2s ease;
    }
    .field::placeholder{ color: var(--field-placeholder); }
    .field:focus{
      border-color: rgba(0,245,160,.55);
      box-shadow: 0 0 0 4px rgba(0,245,160,.12);
    }

    /* Password wrap to hold eye icon */
    .pw-wrap{ position:relative; }
    .pw-eye{
      position:absolute;
      right:10px;
      top:50%;
      transform: translateY(-50%);
      width:34px;
      height:34px;
      border-radius: 9px;
      display:flex;
      align-items:center;
      justify-content:center;
      border: 1px solid rgba(255,255,255,.10);
      background: rgba(0,0,0,.18);
      color: rgba(255,255,255,.70);
      cursor:pointer;
      user-select:none;
      transition: background .2s ease, color .2s ease;
    }
    .pw-eye:hover{
      background: rgba(0,0,0,.28);
      color: rgba(255,255,255,.92);
    }

    /* Row: remember + forgot */
    .row2{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:10px;
      margin: 12px 0 14px;
    }
    .remember{
      display:flex;
      align-items:center;
      gap:8px;
      color: rgba(255,255,255,.65);
      font-size: 12px;
      user-select:none;
    }
    .remember input{
      width:14px; height:14px;
      accent-color: var(--accent);
    }

    .forgot{
      font-size: 12px;
      color: var(--link);
      text-decoration:none;
      font-weight:600;
    }
    .forgot:hover{ text-decoration:underline; }

    /* Footer */
    .footer{
      text-align:center;
      margin-top: 14px;
      font-size: 12px;
      color: rgba(255,255,255,.58);
    }
    .footer a{
      color: var(--link);
      font-weight:700;
      text-decoration:none;
    }
    .footer a:hover{ text-decoration:underline; }

    /* ===== ✅ Google + Sign In unified bar (SHORT, ATTRACTIVE, NO WEIRD HOVER) ===== */
    .auth-bar{
      display:flex;
      align-items:center;
      width:100%;
      max-width: 300px;          /* ✅ short width */
      margin: 6px auto 0;        /* ✅ center */
      height:40px;
      border-radius:10px;
      overflow:hidden;
      background: linear-gradient(90deg, var(--accent2), var(--accent));
      box-shadow: 0 10px 22px rgba(0,0,0,.35);
      transition: box-shadow .25s ease, filter .25s ease;
    }
    .auth-bar:hover{
      filter: brightness(1.05);
      box-shadow: 0 14px 28px rgba(0,245,160,.35);
    }

    .google-login{
      width:40px;
      min-width:40px;
      height:100%;
      background:#ffffff;
      display:flex;
      align-items:center;
      justify-content:center;
      text-decoration:none;
      border-right:1px solid rgba(0,0,0,.08);
    }

    .google-icon{
      width:20px;
      height:20px;
      border-radius:50%;
      display:flex;
      align-items:center;
      justify-content:center;
      font-weight:800;
      font-size:24px;
      color:#00d080;
      background:#ffffff;
    }

    .btn-login{
      flex:1;
      height:100%;
      border:none;
      background:transparent;
      color:#062018;
      font-weight:800;
      font-size:20px;
      letter-spacing:.25px;
      cursor:pointer;
      transition: color .2s ease;
    }
    .btn-login:hover{ color:#041c14; }

    /* Mobile */
    @media (max-width: 420px){
      .login-card{ padding: 20px 16px 16px; }
      .title{ font-size: 20px; }
      .field{ padding: 11px 12px; }

      .auth-bar{ max-width: 280px; height: 38px; }
      .google-login{ width:38px; min-width:38px; }
      .btn-login{ font-size:12.5px; }
    }
  </style>
</head>

<body>

  <div class="login-card">
    <div class="title">Login</div>

    <form action="/login" method="POST">

      <label class="label" for="email">Email</label>
      <input class="field" id="email" name="email" type="email" placeholder="Enter email" required>

      <label class="label" for="password" style="margin-top:12px;">Password</label>
      <div class="pw-wrap">
        <input class="field" id="password" name="password" type="password" placeholder="Enter password" required style="padding-right:48px;">
        <div class="pw-eye" id="togglePwd" title="Show/Hide">
          <i class="bi bi-eye-slash" id="eyeIcon"></i>
        </div>
      </div>

      <div class="row2">
        <label class="remember">
          <input type="checkbox" name="remember">
          Remember me
        </label>
        <a class="forgot" href="/forgot-password">Forgot-Password?</a>
      </div>

      <!-- ✅ Short + Attractive Google icon + Sign In -->
      <div class="auth-bar">
        <a href="/auth/google" class="google-login" title="Sign in with Google">
         <span class="google-icon">
  <svg width="16" height="16" viewBox="0 0 48 48">
    <path fill="#EA4335" d="M24 9.5c3.54 0 6.06 1.54 7.46 2.83l5.45-5.45C33.58 3.64 29.19 1.5 24 1.5 14.73 1.5 6.91 6.97 3.69 14.84l6.36 4.94C11.6 13.04 17.34 9.5 24 9.5z"/>
    <path fill="#4285F4" d="M46.5 24c0-1.54-.14-3.02-.39-4.44H24v8.41h12.7c-.55 2.97-2.22 5.49-4.7 7.18l7.22 5.61C43.36 36.92 46.5 30.96 46.5 24z"/>
    <path fill="#FBBC05" d="M10.05 28.78c-.46-1.38-.72-2.85-.72-4.28 0-1.44.26-2.9.72-4.28l-6.36-4.94C2.44 18.1 1.5 20.97 1.5 24c0 3.03.94 5.9 2.19 8.72l6.36-4.94z"/>
    <path fill="#34A853" d="M24 46.5c5.19 0 9.58-1.72 12.77-4.74l-7.22-5.61c-2.01 1.35-4.59 2.15-7.55 2.15-6.66 0-12.4-3.54-15.95-8.28l-6.36 4.94C6.91 41.03 14.73 46.5 24 46.5z"/>
  </svg>
</span>
        </a>

        <button class="btn-login" type="submit">Login</button>
      </div>

      <div class="footer">
        Don’t have an account? <a href="/register">Register</a>
      </div>

    </form>
  </div>

  <script>
    const toggle = document.getElementById("togglePwd");
    const pwd = document.getElementById("password");
    const icon = document.getElementById("eyeIcon");

    toggle.addEventListener("click", () => {
      const isPass = pwd.type === "password";
      pwd.type = isPass ? "text" : "password";
      icon.classList.toggle("bi-eye", isPass);
      icon.classList.toggle("bi-eye-slash", !isPass);
    });
  </script>

</body>
</html>
